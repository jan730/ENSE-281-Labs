<%- include("layouts/header") -%>

<div class="nv-history-wrapper">
  <%- include("partials/logout-block", { username }) -%>

  <div class="nv-notes-list">
    <% posts.forEach(post => { 
         const isMine = post.creator === username;
         const iUpvoted = post.upvotes.includes(username);
         const iDownvoted = post.downvotes.includes(username);
         const score = post.upvotes.length - post.downvotes.length;
    %>

      <% if (isMine) { %>
        <%- include("partials/post-own", { post, username, score }) -%>
      <% } else if (iUpvoted) { %>
        <%- include("partials/post-upvoted", { post, username, score }) -%>
      <% } else if (iDownvoted) { %>
        <%- include("partials/post-downvoted", { post, username, score }) -%>
      <% } else { %>
        <%- include("partials/post-neutral", { post, username, score }) -%>
      <% } %>

    <% }) %>
  </div>

  <!-- Add Post -->
<form action="/addpost" method="post" class="nv-add-note-row">
  <input
    type="text"
    class="form-control nv-add-input"
    name="text"
    placeholder="Enter a new note here"
    required
  />
  <button class="btn btn-primary nv-add-button" type="submit">
    Add
  </button>
</form>
</div>

<%- include("layouts/footer") -%>